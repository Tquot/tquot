# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# Parser config
PARSER_MAX_QUESTION_ROUNDS=2
PARSER_MAX_INPUT_CHARS=8000

# Session storage (default: in-memory, no config needed)
# Para producción, cambiar a "redis" y configurar REDIS_URL
SESSION_STORE=memory
# REDIS_URL=redis://localhost:6379
