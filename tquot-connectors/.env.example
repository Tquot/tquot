# ─────────────────────────────────────────────────────────────
# Supabase (debería estar ya en tu proyecto)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sk-service-role-key

# ─────────────────────────────────────────────────────────────
# CLAVE DE ENCRIPTACIÓN DE CREDENCIALES (CRÍTICO)
# ─────────────────────────────────────────────────────────────
#
# Esta clave NO se usa en el código TS. Se configura en la BD de Supabase
# antes de aplicar la migración:
#
#   ALTER DATABASE postgres SET app.credentials_key = 'pon-aqui-una-clave-larga-y-aleatoria';
#
# Generar con: openssl rand -base64 48
#
# La clave debe estar guardada de forma segura (1Password, Vault, etc.).
# Si se pierde, NO se pueden descifrar las credenciales guardadas y hay
# que pedir a cada agencia que las reintroduzca.
